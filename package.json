{
  "name": "expub-tool",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./svg-utils": {
      "import": "./dist/esm/svg-utils/index.mjs",
      "require": "./dist/cjs/svg-utils/index.cjs",
      "types": "./dist/types/svg-utils/index.d.ts"
    },
    "./smil": {
      "import": "./dist/esm/smil/index.mjs",
      "require": "./dist/cjs/smil/index.cjs",
      "types": "./dist/types/smil/index.d.ts"
    },
    "./css": {
      "import": "./dist/esm/css/index.mjs",
      "require": "./dist/cjs/css/index.cjs",
      "types": "./dist/types/css/index.d.ts"
    },
    "./utils": {
      "import": "./dist/esm/utils/index.mjs",
      "require": "./dist/cjs/utils/index.cjs",
      "types": "./dist/types/utils/index.d.ts"
    },
    "./behaviors": {
      "import": "./dist/esm/behaviors/index.mjs",
      "require": "./dist/cjs/behaviors/index.cjs",
      "types": "./dist/types/behaviors/index.d.ts"
    },
    "./html": {
      "import": "./dist/esm/html/index.mjs",
      "require": "./dist/cjs/html/index.cjs",
      "types": "./dist/types/html/index.d.ts"
    },
    "./svg": {
      "import": "./dist/esm/svg/index.mjs",
      "require": "./dist/cjs/svg/index.cjs",
      "types": "./dist/types/svg/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --config vite.playground.config.ts",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:playground": "vite build --config vite.playground.config.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@types/chroma-js": "^3.1.2",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "gradient-parser": "^1.2.0",
    "lodash": "^4.18.1"
  }
}
